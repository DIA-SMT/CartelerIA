NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
# "Preguntale al mapa" (Fase 4c) — clave server-side de OpenRouter. Sin ella, la
# interpretación cae automáticamente al intérprete por reglas.
OPENROUTER_API_KEY=
# Opcional: modelo de OpenRouter (default anthropic/claude-3.5-haiku).
# Elegí el slug exacto en https://openrouter.ai/models
OPENROUTER_MODEL=
# RAG documental (Fase 5) — embeddings LOCALES (Transformers.js): sin API key ni
# costo. El modelo se descarga solo la primera vez (cacheado).
# Service-role key de Supabase (Settings → API). SOLO la necesita la ingesta
# (scripts/ingest-docs.ts) para escribir bypassando RLS. NUNCA en el cliente.
SUPABASE_SERVICE_ROLE_KEY=
